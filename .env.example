# Last One Wins dapp configuration. Copy to .env and fill in.
#
# Last One Wins is public — no JWT or platform login is required. Wallet
# operations are signed client-side via the bridge (native Usernode channel
# inside the Flutter WebView, QR fallback in a desktop browser). Server-side
# payouts (when the timer expires) are signed by APP_SECRET_KEY against the
# sidecar /wallet/send RPC.

# The game's on-chain pot address (the destination users send entries to,
# and the source the winner is paid from). Generate via:
#   node ../usernode-dapp-starter/scripts/generate-keypair.js --env
# in this repo's root, or paste an existing pot address (e.g. the canonical
# pot at ut1y8t50glzr7gm424yxm0tpkkyr8w5q64933sgd0dm3vzzm9ntwruqjncx05).
APP_PUBKEY=
APP_SECRET_KEY=

# Sidecar node RPC. In social-vibecoding's docker-compose this resolves to
# the usernode-node service via the shared usernode-net network.
NODE_RPC_URL=http://usernode-node:3000

# Countdown duration in milliseconds. Default is 24h. Local-dev mode
# (`--local-dev`) ignores this and uses a fixed 2-minute timer for fast
# iteration.
TIMER_DURATION_MS=86400000

# HTTP port. Matches the platform scaffold's expectation of 3000.
PORT=3000
